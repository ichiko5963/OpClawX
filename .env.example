# OpClawX Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED SETTINGS
# ============================================

# Language for generated posts
# Options: ja (Japanese), en (English), cn (Chinese), ko (Korean), es (Spanish)
VPA_LANG=ja

# Discord webhook URL for daily delivery
# Get from: Discord Server Settings → Integrations → Webhooks
VPA_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ============================================
# OPTIONAL SETTINGS
# ============================================

# Base URL for generated links
# Default: http://localhost:3000
VPA_BASE_URL=https://your-domain.com

# OpenAI API key for AI-enhanced post generation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# News API key for better news collection
# Get from: https://newsapi.org
NEWS_API_KEY=...

# Timezone for cron scheduling
# Default: Asia/Tokyo
TZ=Asia/Tokyo

# ============================================
# ADVANCED SETTINGS
# ============================================

# Custom patterns config path
VPA_PATTERNS_CONFIG=./config/patterns.json

# Output directory for daily posts
VPA_OUTPUT_DIR=./web/daily

# Log level: debug, info, warn, error
VPA_LOG_LEVEL=info
