# OpClawX Configuration

# ============================================
# AI API Keys (Required - at least one)
# ============================================

# OpenAI API Key (for GPT-4)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API Key (for Claude - recommended)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# OpenClaw Memory Integration (Optional but recommended)
# ============================================

# Path to OpenClaw workspace
OPENCLAW_WORKSPACE=/Users/yourname/Documents/OpenClaw-Workspace

# Enable memory analysis
VPA_USE_MEMORY=true

# Custom memory directory (if different from default)
# VPA_MEMORY_DIR=./memory

# ============================================
# X Premium Integration (Optional)
# ============================================

# Path to X Premium analytics export
XPREMIUM_DATA_PATH=./data/x-premium-export.csv

# ============================================
# News Fetching (Optional)
# ============================================

# Enable news fetching for trending topics
VPA_FETCH_NEWS=true

# ============================================
# AI Generation Settings
# ============================================

# Preferred AI model: 'claude' or 'openai'
VPA_AI_MODEL=claude

# ============================================
# Delivery & Output
# ============================================

# Discord/Slack webhook URL for notifications
VPA_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Base URL for generated links
VPA_BASE_URL=https://your-domain.com

# Output directory for daily posts
VPA_OUTPUT_DIR=./web/daily

# ============================================
# Language & Schedule
# ============================================

# Default language: ja, en, cn, ko, es
VPA_LANG=ja

# Timezone
TZ=Asia/Tokyo
