# OpClawX Configuration
# All settings are OPTIONAL - the system works out of the box!

# ============================================
# AI API Keys (Optional - for enhanced generation)
# ============================================
# If you have OpenAI or Claude API keys, the system will use AI for smarter posts.
# If not provided, it uses intelligent templates based on your memory.
# 
# Get OpenAI key: https://platform.openai.com/api-keys
# Get Claude key: https://console.anthropic.com/
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Preferred AI model (if API keys are set)
# Options: 'claude', 'openai', 'kimi', 'none'
VPA_AI_MODEL=none

# ============================================
# OpenClaw Memory Integration (Recommended)
# ============================================
# Connects to your OpenClaw workspace to learn your style and experiences.
# Highly recommended but not required.
OPENCLAW_WORKSPACE=/Users/yourname/Documents/OpenClaw-Workspace
VPA_USE_MEMORY=true

# ============================================
# X Premium Analytics (Optional - improves accuracy)
# ============================================
# Adding X Premium data makes posts more tailored to your audience,
# but the system works great without it!
# Export: X Premium → Analytics → Export Data
XPREMIUM_DATA_PATH=

# ============================================
# Language Settings
# ============================================
# Default language. Options: en, ja, cn, ko, es
VPA_LANG=en

# ============================================
# Delivery Settings
# ============================================
# Discord/Slack webhook for daily notifications
VPA_WEBHOOK_URL=

# Base URL for your deployed instance
VPA_BASE_URL=https://your-domain.com

# ============================================
# Schedule
# ============================================
TZ=UTC
