{
  "version": 2,
  "name": "opclawx",
  "framework": null,
  "builds": [
    {
      "src": "./index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/daily",
      "dest": "/daily.html"
    },
    {
      "src": "/daily/(.*)",
      "dest": "/daily.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
