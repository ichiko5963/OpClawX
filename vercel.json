{
  "version": 2,
  "name": "opclawx",
  "public": true,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/daily/(.*)",
      "dest": "/daily.html"
    },
    {
      "src": "/daily",
      "dest": "/daily.html"
    },
    {
      "src": "/daily\\.html",
      "dest": "/daily.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/daily/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
